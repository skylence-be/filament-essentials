{
    "name": "skylence/filament-essentials",
    "description": "Meta-package with essential Filament plugins",
    "keywords": ["filament", "laravel", "essentials", "meta-package"],
    "license": "MIT",
    "authors": [
        {
            "name": "Jonas Vanderhaegen",
            "email": "jonas@skylence.be"
        }
    ],
    "require": {
        "php": "^8.3",
        "bezhansalleh/filament-shield": "^4.2",
        "filament/filament": "^5.0",
        "skylence/filament-context-sidebar": "^1.0",
        "skylence/filament-mega-menu": "^1.0",
        "skylence/filament-system-configuration": "^1.0",
        "skylence/filament5-glass-theme": "^1.0",
        "stephenjude/filament-feature-flags": "^5.0"
    },
    "require-dev": {
        "bezhansalleh/filament-plugin-essentials": "^1.2",
